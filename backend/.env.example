# ─── LLM Providers ────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...              # Optional: for Financial Risk agent
FEATHERLESS_API_KEY=fl-...         # For Red Team agent (open-source models)

# ─── Band SDK ─────────────────────────────────────────────────
BAND_API_KEY=band_...
BAND_WORKSPACE_ID=ws_...

# ─── Vector Store (Qdrant) ────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                    # Leave empty for local Docker

# ─── Observability ────────────────────────────────────────────
AGENTOPS_API_KEY=ao_...

# ─── Application ──────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000
